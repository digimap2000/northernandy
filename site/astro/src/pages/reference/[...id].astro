---
import { getCollection, render } from "astro:content";
import ArchiveEntryLayout from "../../layouts/ArchiveEntryLayout.astro";
import { withBase } from "../../lib/archive";

export async function getStaticPaths() {
  const entries = await getCollection("reference");
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ArchiveEntryLayout
  collection="reference"
  entry={entry}
  title={entry.data.title}
  description={entry.data.description ?? entry.data.summary}
>
  <div class="action-row">
    <a class="button secondary" href={withBase("/reference/")}>Back to reference</a>
  </div>
  <Content />
</ArchiveEntryLayout>

