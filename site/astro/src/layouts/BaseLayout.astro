---
import "../styles/site.css";
import { withBase } from "../lib/archive";

const { title = "northernandy", description = "Durable project archive rendered through Astro." } = Astro.props;
const pathname = Astro.url.pathname;

const navigation = [
  { label: "Home", href: withBase("/") },
  { label: "Projects", href: withBase("/projects/") },
  { label: "Logs", href: withBase("/logs/") },
  { label: "Notes", href: withBase("/notes/") },
  { label: "Reference", href: withBase("/reference/") },
  { label: "Derived", href: withBase("/derived/social/") }
];

function isActive(href: string) {
  if (href === withBase("/")) {
    return pathname === href;
  }

  return pathname.startsWith(href);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <div class="page-shell">
      <header class="site-header">
        <div class="wrap masthead">
          <div class="brand-block">
            <a class="brand" href={withBase("/")}>northernandy</a>
            <p class="brand-note">Project records, field notes, reference, and derived material.</p>
          </div>
          <nav class="site-nav" aria-label="Primary">
            {navigation.map((item) => (
              <a class={isActive(item.href) ? "is-active" : undefined} href={item.href}>{item.label}</a>
            ))}
          </nav>
        </div>
        <div class="wrap header-context">
          <p class="header-copy">Static site in front, portable archive underneath.</p>
          <a class="header-link" href={withBase("/projects/")}>Open current work</a>
        </div>
      </header>
      <main class="wrap">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="wrap footer-grid">
          <p>Local Markdown and static assets hold the durable record.</p>
          <p>Projects, logs, notes, reference, and derived outputs stay separable from the renderer.</p>
        </div>
      </footer>
    </div>
  </body>
</html>

